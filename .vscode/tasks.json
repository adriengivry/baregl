{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Generate Projects",
      "type": "shell",
      "command": "./gen_proj_linux.sh",
      "windows": {
        "command": ".\\gen_proj_windows.bat"
      }
    },
    {
      "label": "Build all",
      "type": "shell",
      "command": "cmake --build ${workspaceFolder}/build --config Debug"
    },
    {
      "label": "Build baregl",
      "type": "shell",
      "command": "cmake --build ${workspaceFolder}/build --config Debug --target baregl"
    },
    {
      "label": "Build 1-triangle",
      "type": "shell",
      "command": "cmake --build ${workspaceFolder}/build --config Debug --target 1-triangle"
    },
    {
      "label": "Build 2-cube",
      "type": "shell",
      "command": "cmake --build ${workspaceFolder}/build --config Debug --target 2-cube"
    },
    {
      "label": "Build 3-framebuffer",
      "type": "shell",
      "command": "cmake --build ${workspaceFolder}/build --config Debug --target 3-framebuffer"
    },
    {
      "label": "Build 4-geometry",
      "type": "shell",
      "command": "cmake --build ${workspaceFolder}/build --config Debug --target 4-geometry"
    },
    {
      "label": "Build 5-compute",
      "type": "shell",
      "command": "cmake --build ${workspaceFolder}/build --config Debug --target 5-compute"
    },
    {
      "label": "Build 6-tessellation",
      "type": "shell",
      "command": "cmake --build ${workspaceFolder}/build --config Debug --target 6-tessellation"
    },
    {
      "label": "Clean",
      "type": "shell",
      "command": "rm -rf ${workspaceFolder}/build/",
      "windows": {
        "command": "rd /s /q ${workspaceFolder}\\build\\"
      }
    }
  ]
}
