{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug BareGL Project",
      "type": "lldb",
      "request": "launch",
      "cwd": "${workspaceFolder}/build/full-ninja-multi/bin/${input:buildConfig}/${input:projectName}/",
      "program": "${workspaceFolder}/build/full-ninja-multi/bin/${input:buildConfig}/${input:projectName}/${input:projectName}",
      "windows": {
        "type": "cppvsdbg"
      },
      "preLaunchTask": "Build ${input:projectName} (${input:buildConfig})"
    }
  ],
  "inputs": [
    {
      "id": "projectName",
      "type": "pickString",
      "description": "Select project to debug",
      "options": [
        "1-triangle",
        "2-cube",
        "3-framebuffer",
        "4-geometry",
        "5-compute",
        "6-tessellation",
        "tests"
      ],
      "default": "1-triangle"
    },
    {
      "id": "buildConfig",
      "type": "pickString",
      "description": "Select build configuration",
      "options": [
        "Debug",
        "Release"
      ],
      "default": "Debug"
    }
  ]
}
