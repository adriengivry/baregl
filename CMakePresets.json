{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 25,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "binaryDir": "${sourceDir}/build"
    },
    {
      "name": "dev",
      "inherits": "base",
      "cacheVariables": {
        "BAREGL_GENERATE_EXAMPLES": "ON",
        "BAREGL_GENERATE_TESTS": "ON",
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "lib",
      "inherits": "base",
      "cacheVariables": {
        "BAREGL_GENERATE_EXAMPLES": "OFF",
        "BAREGL_GENERATE_TESTS": "OFF",
        "CMAKE_BUILD_TYPE": "Release"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "dev-tests",
      "targets": "tests",
      "configurePreset": "dev",
      "configuration": "Debug"
    },
    {
      "name": "dev-examples",
      "targets": "examples",
      "configurePreset": "dev",
      "configuration": "Debug"
    },
    {
      "name": "dev-all",
      "targets": ["examples", "tests"],
      "configurePreset": "dev",
      "configuration": "Debug"
    },
    {
      "name": "lib",
      "configurePreset": "lib",
      "configuration": "Release"
    }
  ],
  "testPresets": [
    {
      "name": "test-all",
      "displayName": "Test All",
      "configurePreset": "dev",
      "configuration": "Debug"
    }
  ],
  "workflowPresets": [
    {
      "name": "tests",
      "displayName": "Tests",
      "description": "Configure, build, and run tests",
      "steps": [
        {
          "type": "configure",
          "name": "dev"
        },
        {
          "type": "build",
          "name": "dev-tests"
        },
        {
          "type": "test",
          "name": "test-all"
        }
      ]
    },
    {
      "name": "examples",
      "displayName": "Examples",
      "description": "Configure and build examples",
      "steps": [
        {
          "type": "configure",
          "name": "dev"
        },
        {
          "type": "build",
          "name": "dev-examples"
        }
      ]
    },
    {
      "name": "lib",
      "displayName": "lib",
      "description": "Configure and build library",
      "steps": [
        {
          "type": "configure",
          "name": "lib"
        },
        {
          "type": "build",
          "name": "lib"
        }
      ]
    }
  ]
}
