{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 25,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "binaryDir": "${sourceDir}/build"
    },
    {
      "name": "dev",
      "inherits": "base",
      "cacheVariables": {
        "BAREGL_GENERATE_EXAMPLES": "ON",
        "BAREGL_GENERATE_TESTS": "ON",
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "dev-no-wayland",
      "inherits": "dev",
      "cacheVariables": {
        "GLFW_BUILD_WAYLAND": "OFF"
      }
    },
    {
      "name": "lib",
      "inherits": "base",
      "cacheVariables": {
        "BAREGL_GENERATE_EXAMPLES": "OFF",
        "BAREGL_GENERATE_TESTS": "OFF",
        "CMAKE_BUILD_TYPE": "Release"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "dev-tests",
      "targets": "tests",
      "configurePreset": "dev",
      "configuration": "Debug"
    },
    {
      "name": "dev-examples",
      "targets": "examples",
      "configurePreset": "dev",
      "configuration": "Debug"
    },
    {
      "name": "dev-all",
      "configurePreset": "dev",
      "configuration": "Debug"
    },
    {
      "name": "lib",
      "configurePreset": "lib",
      "configuration": "Release"
    }
  ],
  "testPresets": [
    {
      "name": "test-all",
      "displayName": "Test All",
      "configurePreset": "dev",
      "configuration": "Debug"
    }
  ]
}
